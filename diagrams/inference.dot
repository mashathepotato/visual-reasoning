digraph Inference {
  graph [
    rankdir=LR,
    fontsize=18,
    fontname="Helvetica",
    labelloc="t",
    label="FoT Inference: Controller–Sketcher Loop",
    bgcolor="white",
    compound=true,
    splines=ortho,
    nodesep=0.35,
    ranksep=0.65
  ];

  node [
    shape=box,
    style="rounded,filled",
    fillcolor="white",
    color="#2A4A7B",
    penwidth=1.2,
    fontname="Helvetica",
    fontsize=12
  ];

  edge [
    color="#2A4A7B",
    penwidth=1.2,
    arrowsize=0.9,
    fontname="Helvetica",
    fontsize=10
  ];

  dataset [
    label=<
      <FONT FACE="Helvetica">Dataset</FONT><BR/>
      <FONT FACE="Times New Roman" POINT-SIZE="20"><I>𝒟</I></FONT>
    >,
    fillcolor="#F5F7FA"
  ];

  sample [
    label=<
      <FONT FACE="Helvetica">Sample</FONT><BR/>
      <FONT FACE="Times New Roman" POINT-SIZE="20">(<I>I</I>, <I>o</I>)</FONT>
    >,
    fillcolor="#F5F7FA"
  ];

  input [
    label=<
      <FONT FACE="Helvetica">Input image</FONT><BR/>
      <FONT FACE="Times New Roman" POINT-SIZE="20"><I>I</I></FONT>
    >,
    fillcolor="#F5F7FA"
  ];

  truth [
    label=<
      <FONT FACE="Helvetica">Ground truth label</FONT><BR/>
      <FONT FACE="Times New Roman" POINT-SIZE="20"><I>o</I></FONT>
    >,
    fillcolor="#F5F7FA"
  ];

  output [
    label=<
      <FONT FACE="Helvetica">Predicted output</FONT><BR/>
      <FONT FACE="Times New Roman" POINT-SIZE="20"><I>o</I>′</FONT>
    >,
    fillcolor="#F5F7FA"
  ];

  compare [
    label=<
      <FONT FACE="Helvetica">Compare (train / eval)</FONT><BR/>
      <FONT FACE="Times New Roman" POINT-SIZE="20"><I>o</I>′</FONT>
      <FONT FACE="Helvetica"> vs </FONT>
      <FONT FACE="Times New Roman" POINT-SIZE="20"><I>o</I></FONT><BR/>
      <FONT FACE="Helvetica">(metric / loss)</FONT>
    >,
    fillcolor="#F5F7FA"
  ];

  subgraph cluster_loop {
    label="Inference loop";
    fontname="Helvetica";
    fontsize=14;
    color="#7AA6D8";
    style="rounded,filled";
    fillcolor="#EAF2FF";

    controller [
      label=<
        <FONT FACE="Helvetica">Controller</FONT><BR/>
        <FONT FACE="Helvetica">(VLM + CoT)</FONT><BR/>
        <FONT FACE="Helvetica">selects action </FONT>
        <FONT FACE="Times New Roman" POINT-SIZE="16"><I>a</I><SUB><I>k</I></SUB></FONT>
      >
    ];

    sketcher [
      label=<
        <FONT FACE="Helvetica">Sketcher</FONT><BR/>
        <FONT FACE="Helvetica">(Generative model)</FONT><BR/>
        <FONT FACE="Helvetica">produces visual </FONT>
        <FONT FACE="Times New Roman" POINT-SIZE="16"><I>v</I><SUB><I>k</I></SUB></FONT>
      >
    ];

    controller:ne -> sketcher:nw;
    sketcher:sw -> controller:se;
  }

  dataset -> sample;
  sample -> input;
  sample -> truth;

  { rank=same; input; truth; }

  input -> controller;
  input -> sketcher [style=dashed, constraint=false];
  controller -> output;

  output -> compare;
  truth -> compare;
}
