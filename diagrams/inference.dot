digraph Inference {
  graph [
    rankdir=TB,
    fontsize=18,
    fontname="Helvetica",
    labelloc="t",
    label="FoT Inference: Controller–Sketcher Loop",
    bgcolor="white",
    compound=true,
    splines=ortho,
    nodesep=0.25,
    ranksep=0.45,
    margin=0.04
  ];

  node [
    shape=box,
    style="rounded,filled",
    fillcolor="white",
    color="#2A4A7B",
    penwidth=1.2,
    fontname="Helvetica",
    fontsize=11
  ];

  edge [
    color="#2A4A7B",
    penwidth=1.2,
    arrowsize=0.9,
    fontname="Helvetica",
    fontsize=10
  ];

  dataset [
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLPADDING="0" CELLSPACING="0">
        <TR>
          <TD ALIGN="LEFT"><FONT FACE="Helvetica">Dataset</FONT></TD>
          <TD ALIGN="RIGHT"><FONT FACE="Times New Roman" POINT-SIZE="20"><I>𝒟</I></FONT></TD>
        </TR>
        <TR>
          <TD ALIGN="CENTER" COLSPAN="2">
            <FONT FACE="Times New Roman" POINT-SIZE="20">(<I>I</I>, <I>o</I>)</FONT>
          </TD>
        </TR>
      </TABLE>
    >,
    fillcolor="#F5F7FA"
  ];

  output [
    label=<
      <FONT FACE="Helvetica">Prediction</FONT><BR/>
      <FONT FACE="Times New Roman" POINT-SIZE="20"><I>o</I>′</FONT>
    >,
    fillcolor="#F5F7FA"
  ];

  subgraph cluster_loop {
    label="Inference loop";
    labeljust="r";
    fontname="Helvetica";
    fontsize=14;
    color="#7AA6D8";
    style="rounded,filled";
    fillcolor="#EAF2FF";

    controller [
      label=<
        <FONT FACE="Helvetica">Controller</FONT><BR/>
        <FONT FACE="Helvetica">VLM + CoT</FONT><BR/>
        <FONT FACE="Helvetica">selects action</FONT><BR/>
        <FONT FACE="Times New Roman" POINT-SIZE="18"><I>a</I><SUB><I>k</I></SUB></FONT>
      >
    ];

    sketcher [
      label=<
        <FONT FACE="Helvetica">Sketcher</FONT><BR/>
        <FONT FACE="Helvetica">Generative model</FONT><BR/>
        <FONT FACE="Helvetica">produces visual</FONT><BR/>
        <FONT FACE="Times New Roman" POINT-SIZE="18"><I>v</I><SUB><I>k</I></SUB></FONT>
      >
    ];

    { rank=same; controller; sketcher; }

    controller:ne -> sketcher:nw [constraint=false];
    sketcher:sw -> controller:se [constraint=false];
  }

  { rank=source; dataset; }
  { rank=sink; output; }

  dataset:s -> controller:nw;
  dataset -> sketcher [style=invis, weight=1];
  controller:s -> output:n [minlen=2];
}
